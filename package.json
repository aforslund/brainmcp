{
  "name": "brainmcp",
  "version": "1.0.0",
  "description": "Associative memory graph MCP server — gives LLMs a persistent brain",
  "author": "Andreas Forslund",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aforslund/brainmcp.git"
  },
  "keywords": [
    "mcp",
    "knowledge-graph",
    "memory",
    "llm",
    "claude",
    "sqlite",
    "associative-memory",
    "model-context-protocol"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brainmcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "tsc --noEmit && node --import tsx --test 'src/**/*.test.ts'",
    "viz": "tsc && node dist/visualize.js",
    "explore": "tsc && node dist/explore.js",
    "explore-cc": "tsc && node dist/explore-cc.js",
    "explore-ask": "tsc && node dist/explore-ask.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
